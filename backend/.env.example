# Copy to .env (gitignored) or export these before running.
# Free keys: https://twelvedata.com/ and https://finnhub.io/

# Upstream market data (required for real data; "demo" works for a few sample symbols)
TWELVE_DATA_API_KEY=demo
FINNHUB_API_KEY=

# --- Production profile (SPRING_PROFILES_ACTIVE=prod) only ---
# Postgres (Neon). Note the jdbc: prefix.
# DATABASE_URL=jdbc:postgresql://HOST/DB?sslmode=require
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# Redis (Upstash). Use the TLS endpoint.
# REDIS_URL=rediss://default:PASSWORD@HOST:6379
# CORS (comma-separated allowed origins for the deployed frontend)
# CORS_ORIGINS=https://your-app.vercel.app
